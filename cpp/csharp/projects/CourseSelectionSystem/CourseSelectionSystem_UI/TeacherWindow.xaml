<Window x:Class="CourseSelectionSystem_UI.TeacherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="教师成绩管理系统" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#3F51B5">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                <TextBlock Text="教师管理端" Foreground="White" FontSize="24" FontWeight="Bold"/>
                <TextBlock Text=" | " Foreground="#AAB6FE" FontSize="20" Margin="10,0"/>
                <TextBlock x:Name="TxtTeacherInfo" Text="欢迎, 老师" Foreground="White" FontSize="18" VerticalAlignment="Bottom"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="选课学生名单" Grid.Column="0" Margin="0,0,10,0" FontSize="16">
                <DataGrid x:Name="GridStudents" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" SelectionMode="Single"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal" Background="White">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="10,5"/>
                            <Setter Property="Background" Value="#E8EAF6"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="学号" Binding="{Binding SNO}" Width="150"/>
                        <DataGridTextColumn Header="姓名" Binding="{Binding SNAME}" Width="100"/>
                        <DataGridTextColumn Header="当前成绩" Binding="{Binding GRADE}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <Border Grid.Column="1" Background="White" CornerRadius="5" Padding="20">
                <Border.Effect>
                    <DropShadowEffect Color="#DDDDDD" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="成绩录入" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" Foreground="#333"/>

                    <TextBlock Text="当前选中学生：" Foreground="Gray" Margin="0,0,0,5"/>
                    <TextBlock x:Name="TxtSelectedStudent" Text="请先在左侧选择学生" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" Foreground="#3F51B5"/>

                    <TextBlock Text="输入成绩：" Foreground="Gray" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtScoreInput" Height="40" FontSize="20" VerticalContentAlignment="Center" Margin="0,0,0,20"/>

                    <Button x:Name="BtnSaveScore" Content="保存 / 更新成绩" Height="45" Background="#4CAF50" Foreground="White" FontSize="16" FontWeight="Bold" Click="BtnSaveScore_Click"/>

                    <TextBlock Text="提示：输入成绩后点击保存即可。" Foreground="#999" Margin="0,20,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>