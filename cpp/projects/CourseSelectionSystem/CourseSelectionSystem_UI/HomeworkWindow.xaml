<Window x:Class="CourseSelectionSystem_UI.HomeworkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="数据库作业 &amp; 高级查询" Height="750" Width="1100"
        WindowStartupLocation="CenterScreen">

	<Window.Resources>
		<Style x:Key="BtnStyle" TargetType="Button">
			<Setter Property="Height" Value="35"/>
			<Setter Property="Margin" Value="0,2"/>
			<Setter Property="HorizontalContentAlignment" Value="Left"/>
			<Setter Property="Padding" Value="10,0"/>
			<Setter Property="Background" Value="White"/>
			<Setter Property="BorderBrush" Value="#DDD"/>
		</Style>
	</Window.Resources>

	<Grid Background="#F0F2F5">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="280"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>

		<Border Background="White" BorderBrush="#DDD" BorderThickness="0,0,1,0">
			<ScrollViewer VerticalScrollBarVisibility="Auto">
				<StackPanel Margin="10">
					<TextBlock Text="作业任务列表" FontWeight="Bold" FontSize="18" Margin="0,10,0,10" Foreground="#333"/>

					<Button Content="1. 求学生出生年份" Click="BtnTask1_Click" Style="{StaticResource BtnStyle}"/>
					<Button Content="2. 各系人数统计 (降序)" Click="BtnTask2_Click" Style="{StaticResource BtnStyle}"/>
					<Button Content="3. CS103/123 课程成绩" Click="BtnTask3_Click" Style="{StaticResource BtnStyle}"/>
					<Button Content="4. 选课超3人的教师" Click="BtnTask4_Click" Style="{StaticResource BtnStyle}"/>
					<Button Content="5. 未选课学生名单" Click="BtnTask5_Click" Style="{StaticResource BtnStyle}"/>
					<Button Content="6. 每个学生最高分" Click="BtnTask6_Click" Style="{StaticResource BtnStyle}"/>
					<Button Content="7. 教'数据结构'的老师" Click="BtnTask7_Click" Style="{StaticResource BtnStyle}"/>
					<Button Content="8. '郑大力'老师的学生" Click="BtnTask8_Click" Style="{StaticResource BtnStyle}"/>

					<Separator Margin="0,10"/>
					<TextBlock Text="数据操作 &amp; 视图" FontWeight="Bold" Margin="5"/>
					<Button Content="9. 建表 S1 并插入数据" Click="BtnTask9_Click" Background="#FFF3E0" Style="{StaticResource BtnStyle}"/>
					<Button Content="10. 视图提分 (CS101 +5分)" Click="BtnTask10_Click" Background="#FFF3E0" Style="{StaticResource BtnStyle}"/>

					<Separator Margin="0,10"/>
					<TextBlock Text="存储过程 (需参数)" FontWeight="Bold" Margin="5"/>
					<Button Content="11. 查询成绩段 (存储过程)" Click="BtnTask11_Click" Background="#E8F5E9" Style="{StaticResource BtnStyle}"/>
					<Button Content="12. 删除成绩段 (存储过程)" Click="BtnTask12_Click" Background="#FFEBEE" Style="{StaticResource BtnStyle}"/>

					<Separator Margin="0,10"/>
					<TextBlock Text="其他后端功能" FontWeight="Bold" Margin="5"/>
					<Button Content="13. 按学分查询课程" Click="BtnTask13_Click" Background="#E3F2FD" Style="{StaticResource BtnStyle}"/>
				</StackPanel>
			</ScrollViewer>
		</Border>

		<Grid Grid.Column="1" Margin="20">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<Border Background="White" Padding="15" CornerRadius="8" Margin="0,0,0,15">
				<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
					<TextBlock Text="参数控制台：" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0" FontSize="16"/>

					<TextBlock Text="最低分/学分：" VerticalAlignment="Center"/>
					<TextBox x:Name="TxtParam1" Width="80" Margin="5,0,15,0" Padding="3" Text="0"/>

					<TextBlock Text="最高分：" VerticalAlignment="Center"/>
					<TextBox x:Name="TxtParam2" Width="80" Margin="5,0,15,0" Padding="3" Text="100"/>

					<TextBlock Text="(仅任务 11,12,13 需要输入)" Foreground="Gray" VerticalAlignment="Center" FontSize="12"/>
				</StackPanel>
			</Border>

			<DataGrid x:Name="GridResults" Grid.Row="1" Background="White" AutoGenerateColumns="True" IsReadOnly="True" HeadersVisibility="Column">
				<DataGrid.ColumnHeaderStyle>
					<Style TargetType="DataGridColumnHeader">
						<Setter Property="Padding" Value="10,8"/>
						<Setter Property="Background" Value="#F5F5F5"/>
						<Setter Property="FontWeight" Value="Bold"/>
					</Style>
				</DataGrid.ColumnHeaderStyle>
			</DataGrid>
		</Grid>
	</Grid>
</Window>