<Window x:Class="CourseSelectionSystem_UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选课系统主界面" Height="600" Width="900"
        WindowState="Maximized" 
        WindowStartupLocation="CenterScreen">

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2D2D30" Padding="25,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">

                    <TextBlock Text="学生选课系统" Foreground="White" FontWeight="Bold" FontSize="28" 
                               VerticalAlignment="Center" FontFamily="Microsoft YaHei UI">
                        <TextBlock.Effect>
                            <DropShadowEffect ShadowDepth="2" Direction="315" Color="Black" Opacity="0.5" BlurRadius="5"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="当前登录：" Foreground="#AAAAAA" FontSize="16" VerticalAlignment="Bottom" Margin="0,0,5,4"/>

                    <TextBlock x:Name="TxtWelcome" Text="正在读取..." Foreground="White" FontWeight="SemiBold" FontSize="22" VerticalAlignment="Bottom" FontFamily="Microsoft YaHei UI"/>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="10">
            <TabItem Header="选课列表">
                <Grid Background="White">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                        <Button x:Name="BtnRefreshCourse" Content="刷新列表" Width="80" Height="30" Click="BtnRefreshCourse_Click" Margin="0,0,10,0"/>
                        <Button x:Name="BtnSelectCourse" Content="我要选这门课" Width="100" Height="30" Click="BtnSelectCourse_Click" Background="#4CAF50" Foreground="White"/>
                    </StackPanel>

                    <DataGrid x:Name="GridCourses" Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True" 
                              SelectionMode="Single" Margin="5"/>
                </Grid>
            </TabItem>

            <TabItem Header=" 我的成绩 ">
                <Grid Background="White">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                        <Button x:Name="BtnRefreshScore" Content="刷新成绩" Width="80" Height="30" Click="BtnRefreshScore_Click" Margin="0,0,10,0"/>
                        <Button x:Name="BtnWithdraw" Content="退选课程" Width="80" Height="30" Click="BtnWithdraw_Click" Background="#F44336" Foreground="White" FontWeight="Bold"/>
                    </StackPanel>

                    <DataGrid x:Name="GridScores" Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True" Margin="5"/>
                </Grid>
            </TabItem>
            
        </TabControl>
    </Grid>
</Window>
