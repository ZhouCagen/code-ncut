@using System.Data
@model Tuple<DataTable, DataTable>
@{
    Layout = null; string userId = ViewData["UserID"].ToString()!;
}

<!DOCTYPE html>
<html>
<head>
    <title>学生选课系统</title>
    <style>
        body {
            font-family: "Microsoft YaHei";
            background: #2D2D30;
            color: #EEE;
            margin: 0;
            display: flex;
            flex-direction: column;
            height: 100vh;
        }

        /* 顶部栏 */
        .header {
            background: #1E1E1E;
            padding: 15px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 2px solid #007ACC;
        }

        .title {
            font-size: 24px;
            font-weight: bold;
        }

        /* Tab 按钮区 */
        .tabs {
            padding: 10px 20px;
            background: #252526;
        }

        .tab-btn {
            background: #333;
            color: white;
            border: none;
            padding: 10px 20px;
            cursor: pointer;
            margin-right: 5px;
        }

            .tab-btn.active {
                background: #EEE;
                color: black;
                font-weight: bold;
            }

        /* 内容区 */
        .content {
            flex: 1;
            padding: 20px;
            overflow: auto;
            background: #F0F0F0;
            color: black;
        }

        .page {
            display: none;
        }

            .page.active {
                display: block;
            }

        /* 表格样式 */
        table {
            width: 100%;
            border-collapse: collapse;
            background: white;
            box-shadow: 0 0 5px rgba(0,0,0,0.1);
        }

        th {
            background: #E0E0E0;
            padding: 10px;
            text-align: left;
            border-bottom: 2px solid #AAA;
        }

        td {
            padding: 10px;
            border-bottom: 1px solid #EEE;
        }

        tr:hover {
            background: #E3F2FD;
        }

        /* 按钮 */
        .btn-select {
            background: #4CAF50;
            color: white;
            border: none;
            padding: 5px 10px;
            cursor: pointer;
            border-radius: 3px;
        }

        .btn-withdraw {
            background: #F44336;
            color: white;
            border: none;
            padding: 5px 10px;
            cursor: pointer;
            border-radius: 3px;
        }

        .btn-select:hover {
            background: #45a049;
        }

        .btn-withdraw:hover {
            background: #d32f2f;
        }
    </style>
</head>
<body>
    <div class="header">
        <div class="title">学生选课系统</div>
        <div>当前登录: @userId (学生)</div>
    </div>

    <div class="tabs">
        <button class="tab-btn active" onclick="showTab('courses')">选课列表</button>
        <button class="tab-btn" onclick="showTab('scores')">我的成绩</button>
    </div>

    <div class="content">
        <div id="courses" class="page active">
            <table>
                <thead>
                    <tr><th>课程号</th><th>课程名</th><th>学分</th><th>人数</th><th>操作</th></tr>
                </thead>
                <tbody>
                    @foreach (DataRow row in Model.Item1.Rows)
                    {
                        <tr>
                            <td>@row["CNO"]</td>
                            <td>@row["CNAME"]</td>
                            <td>@row["CCREDIT"]</td>
                            <td>@row["StudentCount"]</td>
                            <td>
                                <button class="btn-select" onclick="selectCourse('@row["CNO"]')">我要选这门课</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div id="scores" class="page">
            <table>
                <thead>
                    <tr><th>课程号</th><th>课程名</th><th>学分</th><th>成绩</th><th>操作</th></tr>
                </thead>
                <tbody>
                    @foreach (DataRow row in Model.Item2.Rows)
                    {
                        <tr>
                            <td>@row["CNO"]</td>
                            <td>@row["CNAME"]</td>
                            <td>@row["CCREDIT"]</td>
                            <td style="color:red; font-weight:bold;">@row["GRADE"]</td>
                            <td>
                                <button class="btn-withdraw" onclick="withdrawCourse('@row["CNO"]')">退课</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <script>
        const userId = '@userId';

        function showTab(tabId) {
            document.querySelectorAll('.page').forEach(el => el.classList.remove('active'));
            document.querySelectorAll('.tab-btn').forEach(el => el.classList.remove('active'));
            document.getElementById(tabId).classList.add('active');
            event.target.classList.add('active');
        }

        async function selectCourse(cno) {
            if(!confirm("确定要选择这门课吗？")) return;
            let form = new FormData();
            form.append('userId', userId);
            form.append('courseId', cno);

            let res = await fetch('/Home/SelectCourse', { method: 'POST', body: form });
            let json = await res.json();
            alert(json.msg);
            if(json.success) location.reload();
        }

        async function withdrawCourse(cno) {
            if(!confirm("确定要退选吗？")) return;
            let form = new FormData();
            form.append('userId', userId);
            form.append('courseId', cno);

            let res = await fetch('/Home/WithdrawCourse', { method: 'POST', body: form });
            let json = await res.json();
            alert(json.msg);
            if(json.success) location.reload();
        }
    </script>
</body>
</html>