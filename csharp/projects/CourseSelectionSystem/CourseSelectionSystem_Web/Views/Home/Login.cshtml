@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>系统登录</title>
    <style>
        body { background-color: #2D2D30; color: white; font-family: "Microsoft YaHei"; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
        .login-box { background-color: #1E1E1E; padding: 40px; border-radius: 5px; box-shadow: 0 0 10px black; width: 300px; }
        h2 { text-align: center; margin-bottom: 30px; }
        input[type="text"] { width: 100%; padding: 10px; margin-bottom: 20px; border: 1px solid #3E3E42; background: #252526; color: white; box-sizing: border-box;}
        button { width: 100%; padding: 10px; background-color: #007ACC; color: white; border: none; cursor: pointer; font-size: 16px; }
        button:hover { background-color: #0098FF; }
        .homework-link { position: absolute; bottom: 10px; right: 10px; color: #555; text-decoration: none; font-size: 12px; cursor: pointer;}
        .homework-link:hover { color: #888; }
        .radio-group { margin-bottom: 20px; text-align: center; }
    </style>
</head>
<body>
    <div class="login-box">
        <h2>学生选课系统</h2>
        <form action="/Home/Login" method="post">
            <input type="text" name="userId" placeholder="请输入 学号 / 工号" required />

            <div class="radio-group">
                <input type="radio" id="stu" name="role" value="Student" checked> <label for="stu">我是学生</label>
                <input type="radio" id="tea" name="role" value="Teacher"> <label for="tea">我是老师</label>
            </div>

            <button type="submit">登 录</button>
        </form>
    </div>

    <a href="/Home/Homework" class="homework-link">⚙️ 开发者/作业模式</a>
</body>
</html>