<Window x:Class="CourseSelectionSystem_UI.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选课系统—登录" Height="350" Width="500"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
			<TextBlock Text="欢迎使用选课系统" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <TextBlock Text="请输入学号/工号 (ID):" Margin="0,5"/>
            <TextBox x:Name="TxtUserId" Height="30" Padding="5"/>
			
			<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
                <RadioButton x:Name="RbStudent" Content="我是学生" IsChecked="True" Margin="0,0,20,0"/>
                <RadioButton x:Name="RbTeacher" Content="我是教师"/>
            </StackPanel>

            <Button x:Name="BtnLogin" Content="登 录" Height="40" Click="BtnLogin_Click" Background="#007ACC" Foreground="White" FontSize="16" FontWeight="Bold"/>
			
		</StackPanel>
        
        <Button Content="⚙️ 作业" 
            HorizontalAlignment="Right" 
            VerticalAlignment="Bottom" 
            Margin="10" 
            Background="Transparent" 
            BorderThickness="0" 
            Foreground="#CCC" 
            FontSize="10"
            Click="BtnDevMode_Click"/>
    </Grid>
    
    

</Window>